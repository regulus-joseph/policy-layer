{
  "name": "policy-layer",
  "version": "0.5.0",
  "type": "module",
  "description": "OpenClaw policy enforcement plugin: Layer 1 (normalize + 25 dangerous patterns), Layer 2 (D' CBS sensorium), Layer 3 (LLM smart-review + fast-lane + JSONL log), Layer 4 (39 secret patterns redaction)",
  "main": "src/index.ts",
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "compat": {
      "pluginApi": "0.5.0"
    },
    "build": {
      "openclawVersion": "2026.5.0"
    }
  },
  "scripts": {
    "build": "esbuild src/index.ts --outdir=dist --format=esm --platform=node --bundle",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.25.2",
    "vitest": "^3.2.4",
    "ws": "^8.20.0"
  }
}
